rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helpers
    function isAuth() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuth() && request.auth.token.email != null;
    }

    function isStaff() {
      // Allow any authenticated user to act as staff
      // In production, verify role in Firestore if needed
      return isAuth();
    }

    // ============= BRANDING (Público) =============
    // Lectura: Pública
    match /branding/{allPaths=**} {
      allow read: if true;
      // Escritura: Solo staff autenticado
      allow write: if isStaff();
    }

    // ============= CLIENT FILES (Privado) =============
    match /client-files/{allPaths=**} {
      // Lectura: Solo staff autenticado
      allow read: if isStaff();
      // Escritura: Solo staff autenticado
      allow write: if isStaff();
    }

    // ============= DEFAULT =============
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

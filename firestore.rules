rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isEditor() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor';
    }

    function isAdvisor() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'asesor';
    }

    function isReception() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'recepcion';
    }

    function isViewer() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'viewer';
    }

    function isStaff() {
      return isAdmin() || isEditor() || isAdvisor() || isReception();
    }

    function isAssignedAdvisor(appointmentId) {
      let appointment = get(/databases/$(database)/documents/appointments/$(appointmentId)).data;
      return isAuth() && appointment.assignedAdvisorId == request.auth.uid;
    }

    function isClientByEmail(email) {
      return isAuth() && request.auth.token.email == email;
    }

    // ============= USERS =============
    match /users/{userId} {
      allow create: if false;
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============= APPOINTMENTS =============
    match /appointments/{appointmentId} {
      allow create: if !isAuth() || isStaff();

      allow read: if isAuth() && (
        isAdmin() ||
        isReception() ||
        isAssignedAdvisor(appointmentId) ||
        (isViewer() && resource.data.email == request.auth.token.email)
      );

      allow update: if isAuth() && (isAdmin() || isReception() || isAssignedAdvisor(appointmentId));

      allow delete: if isAdmin();
    }

    // ============= TRANSACTIONS =============
    match /transactions/{appointmentId} {
      allow write: if isAdmin();
      allow read: if isAuth() && (isAdmin() || isReception());
      allow delete: if isAdmin();
    }

    // ============= VALUATION REPORTS =============
    match /valuation_reports/{appointmentId} {
      allow write: if isAuth() && (isAdmin() || isAssignedAdvisor(appointmentId));

      allow read: if isAuth() && (
        isAdmin() ||
        isAssignedAdvisor(appointmentId) ||
        (isViewer() && get(/databases/$(database)/documents/appointments/$(appointmentId)).data.email == request.auth.token.email)
      );

      allow delete: if isAdmin();
    }

    // ============= CLIENT DOCUMENTS =============
    match /client_documents/{docId} {
      allow create: if isAuth() && (
        isAdmin() ||
        isClientByEmail(get(/databases/$(database)/documents/appointments/$(request.resource.data.appointmentId)).data.email)
      );

      allow read: if isAuth() && (
        isAdmin() ||
        isAssignedAdvisor(resource.data.appointmentId) ||
        (isViewer() && get(/databases/$(database)/documents/appointments/$(resource.data.appointmentId)).data.email == request.auth.token.email)
      );

      allow update: if false;
      allow delete: if isAdmin();
    }

    // ============= SITE SETTINGS =============
    match /site_settings/{document=**} {
      allow create: if false;
      allow read: if true;
      allow update: if isAuth() && (isAdmin() || isEditor());
      allow delete: if false;
    }

    // ============= DEFAULT =============
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
